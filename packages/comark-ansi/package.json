{
  "name": "@comark/ansi",
  "version": "0.4.0",
  "description": "ANSI terminal renderer for Comark (Components in Markdown)",
  "keywords": [
    "ansi",
    "cli",
    "comark",
    "markdown",
    "mdc",
    "renderer",
    "streaming",
    "terminal"
  ],
  "homepage": "https://comark.dev/rendering/ansi",
  "bugs": {
    "url": "https://github.com/comarkdown/comark/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/comarkdown/comark.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./plugins/*": "./dist/plugins/*.js",
    "./utils": "./dist/utils/index.js",
    "./parse": "./dist/parse.js",
    "./render": "./dist/render.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "stub": "node ../../scripts/stub.mjs",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "prepack": "tsc",
    "release": "release-it"
  },
  "dependencies": {
    "comark": "catalog:"
  },
  "devDependencies": {
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "beautiful-mermaid": ">=1.0",
    "katex": ">=0.16",
    "shiki": "catalog:"
  },
  "peerDependenciesMeta": {
    "katex": {
      "optional": true
    },
    "beautiful-mermaid": {
      "optional": true
    },
    "shiki": {
      "optional": true
    }
  }
}
